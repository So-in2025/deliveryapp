{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "avatar": { "type": "string", "description": "URL to user's avatar image" },
        "isDriver": { "type": "boolean", "description": "Whether the user is a driver" },
        "ownedStoreId": { "type": "string", "description": "ID of the store owned by the user" },
        "addresses": { "type": "array", "items": { "type": "string" }, "description": "Saved delivery addresses" },
        "role": { "type": "string", "enum": ["CLIENT", "MERCHANT", "DRIVER", "ADMIN"], "description": "User's role in the platform" },
        "phone": { "type": "string", "description": "User's phone number" },
        "driverLicense": { "type": "string", "description": "Driver's license number" },
        "driverInsurance": { "type": "string", "description": "Driver's insurance policy number" },
        "driverPlate": { "type": "string", "description": "Driver's vehicle plate number" }
      },
      "required": ["name", "email", "role"]
    },
    "Store": {
      "title": "Store",
      "description": "Merchant store information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Store name" },
        "category": { "type": "string", "description": "Store category (e.g., Restaurant, Pharmacy)" },
        "rating": { "type": "number", "description": "Average rating" },
        "reviewsCount": { "type": "integer", "description": "Number of reviews" },
        "deliveryTimeMin": { "type": "integer", "description": "Minimum delivery time in minutes" },
        "deliveryTimeMax": { "type": "integer", "description": "Maximum delivery time in minutes" },
        "deliveryFee": { "type": "number", "description": "Base delivery fee" },
        "image": { "type": "string", "description": "URL to store image" },
        "ownerId": { "type": "string", "description": "UID of the store owner" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the store was created" },
        "customFont": { "type": "string", "description": "Custom font for store UI" },
        "customColor": { "type": "string", "description": "Custom color for store UI" },
        "legalName": { "type": "string", "description": "Legal name of the store owner" },
        "taxId": { "type": "string", "description": "Tax ID of the store" },
        "phone": { "type": "string", "description": "Store contact phone" },
        "bankAccount": { "type": "string", "description": "Bank account for payouts" }
      },
      "required": ["name", "category", "ownerId", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Product in a store",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "description": { "type": "string", "description": "Product description" },
        "price": { "type": "number", "description": "Product price" },
        "image": { "type": "string", "description": "URL to product image" },
        "storeId": { "type": "string", "description": "ID of the store this product belongs to" }
      },
      "required": ["name", "price", "storeId"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order information",
      "type": "object",
      "properties": {
        "storeId": { "type": "string", "description": "ID of the store" },
        "storeName": { "type": "string", "description": "Name of the store" },
        "total": { "type": "number", "description": "Total order amount" },
        "deliveryFee": { "type": "number", "description": "Delivery fee paid" },
        "status": { "type": "string", "description": "Current status of the order" },
        "type": { "type": "string", "enum": ["DELIVERY", "PICKUP"], "description": "Order type" },
        "customerId": { "type": "string", "description": "UID of the customer" },
        "customerName": { "type": "string", "description": "Name of the customer" },
        "driverId": { "type": "string", "description": "UID of the assigned driver" },
        "driverName": { "type": "string", "description": "Name of the assigned driver" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the order was placed" },
        "address": { "type": "string", "description": "Delivery address" },
        "paymentMethod": { "type": "string", "enum": ["CASH", "CARD", "MERCADO_PAGO"], "description": "Payment method used" },
        "paymentStatus": { "type": "string", "enum": ["PENDING", "PAID", "FAILED"], "description": "Status of the payment" },
        "preferenceId": { "type": "string", "description": "Mercado Pago preference ID" },
        "items": { "type": "array", "description": "List of items in the order" },
        "notes": { "type": "string", "description": "Order notes" },
        "isReviewed": { "type": "boolean", "description": "Whether the order has been reviewed" }
      },
      "required": ["storeId", "total", "status", "customerId", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer review for a store",
      "type": "object",
      "properties": {
        "storeId": { "type": "string", "description": "ID of the store" },
        "customerId": { "type": "string", "description": "UID of the customer" },
        "customerName": { "type": "string", "description": "Name of the customer" },
        "rating": { "type": "number", "description": "Rating given" },
        "comment": { "type": "string", "description": "Review comment" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was created" }
      },
      "required": ["storeId", "customerId", "rating", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "Coupon code" },
        "discountPct": { "type": "number", "description": "Discount percentage (0-1)" },
        "active": { "type": "boolean", "description": "Whether the coupon is active" },
        "storeId": { "type": "string", "description": "ID of the store (optional, for store-specific coupons)" }
      },
      "required": ["code", "discountPct", "active"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Store documents"
    },
    "/stores/{storeId}/products/{productId}": {
      "schema": "Product",
      "description": "Products within a store"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order documents"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Review documents"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Coupon documents"
    },
    "/config/global": {
      "schema": "object",
      "description": "Global platform configuration"
    }
  }
}
